   "source": [
    "n=int(input(\"Enter the number : \"))\n",
    "list=[]\n",
    "for i in range(1,n):\n",
    "    if n%i==0:\n",
    "        list.append(i)\n",
    "print(\"Factors of the number \",n,\" are :\",list)        "
   ]
