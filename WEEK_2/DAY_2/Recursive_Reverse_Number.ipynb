      "145\n"
     ]
    }
   ],
   "source": [
    "def rever(n,add=0):\n",
    "    if n==0:\n",
    "        return add\n",
    "    digit=n%10\n",
    "    return rever(n//10,add*10+digit)\n",
    "n=int(input(\"Enter the number : \"))\n",
    "print(rever(n))"
   ]
  }
 ],
