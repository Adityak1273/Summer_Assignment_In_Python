   "source": [
    "Convert Decimal to Binary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "a08390b8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Decimal number 34 to Binary number are : 1 0 0 0 1 0\n"
     ]
    }
   ],
   "source": [
    "n=int(input(\"Enter the  number : \"))\n",
    "list=[]\n",
    "n1=n\n",
    "while n1>0:\n",
    "    a=n1%2\n",
    "    list.append(a)\n",
    "    n1//=2\n",
    "list.reverse()   \n",
    "print(\"Decimal number\",n,\"to Binary number are :\",*list)   "
   ]
  }
 ],
