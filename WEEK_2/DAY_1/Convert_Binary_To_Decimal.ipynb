   "source": [
    "Convert Binary To Decimal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "3d654a00",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Binary number 101 to Decimal number are : 5\n"
     ]
    }
   ],
   "source": [
    "n=int(input(\"Enter the number : \"))\n",
    "add=0\n",
    "i=0\n",
    "n1=n\n",
    "while n1>0:\n",
    "    rem=n1%10\n",
    "    add=add+rem*pow(2,i)\n",
    "    i+=1\n",
    "    n1//=10\n",
    "print(\"Binary number\",n,\"to Decimal number are :\",add)    "
   ]
  }
