   "source": [
    "Count set bits in a number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "9bf5dc54",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Counts of the Bits of a number 45 are : 4\n"
     ]
    }
   ],
   "source": [
    "n=int(input(\"Enter the number : \"))\n",
    "add=0\n",
    "n1=n\n",
    "while n1>0:\n",
    "    rem=n1%2\n",
    "    if rem==1:\n",
    "        add+=1\n",
    "    n1//=2\n",
    "print(\"Counts of the Bits of a number\",n,\"are :\",add)"
   ]
  }
