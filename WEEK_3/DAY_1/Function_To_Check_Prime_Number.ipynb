   "cell_type": "code",
   "execution_count": 4,
   "id": "212c4f78",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'Not a Prime Number'"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def prime(n):\n",
    "    add=0\n",
    "    for i in range(2,n):\n",
    "        if n%i==0:\n",
    "            add+=1\n",
    "    if add==0:\n",
    "        return \"Prime Number\"\n",
    "    else:\n",
    "        return \"Not a Prime Number\"\n",
    "n=int(input(\"Enter the number : \"))    \n",
    "prime(n)"
   ]
  }
 ],
